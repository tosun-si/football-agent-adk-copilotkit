export GCP_PROJECT_ID=gb-poc-373711
export GOOGLE_CLOUD_PROJECT=gb-poc-373711
export BIGQUERY_DATASET=qatar_fifa_world_cup
export BIGQUERY_TABLE=team_players_stat_raw
export GOOGLE_GENAI_USE_VERTEXAI=True
export PROJECT_ID=${GCP_PROJECT_ID}
export LOCATION=europe-west1
export REPO_NAME=internal-images

# Webapp → ADK API. Defaults to local. Override with the Cloud Run URL
# of the deployed Copilot Kit agent (must include the visualization-aware
# system instruction; do NOT point at the upstream football-agent-adk API).
export CLOUD_RUN_API_URL=http://localhost:8080

# Create venv if it doesn't exist (optional in .envrc but good for bootstrap)
if [ ! -d ".venv" ]; then
    uv venv
fi

# Activate venv
source .venv/bin/activate
