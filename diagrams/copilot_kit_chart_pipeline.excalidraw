      "isDeleted": false,
      "boundElements": [],
      "updated": 1772624370051,
      "link": null,
      "locked": false,
      "text": "new CopilotRuntime({\n  agents: {\n    default: new BuiltInAgent({\n      type: \"custom\",\n      factory: async function* (ctx) {\n\n        // call ADK\n        const text = await fetch(\n          `${ADK_URL}/run`, ...\n        );\n\n        // yield AG-UI events\n        yield {\n          type: TEXT_MESSAGE_START,\n          role: \"assistant\"\n        }\n        yield {\n          type: TEXT_MESSAGE_CONTENT,\n          delta: text\n        }\n        yield { type: TEXT_MESSAGE_END }\n      },\n    }),\n  },\n})",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "new CopilotRuntime({\n  agents: {\n    default: new BuiltInAgent({\n      type: \"custom\",\n      factory: async function* (ctx) {\n\n        // call ADK\n        const text = await fetch(\n          `${ADK_URL}/run`, ...\n        );\n\n        // yield AG-UI events\n        yield {\n          type: TEXT_MESSAGE_START,\n          role: \"assistant\"\n        }\n        yield {\n          type: TEXT_MESSAGE_CONTENT,\n          delta: text\n        }\n        yield { type: TEXT_MESSAGE_END }\n      },\n    }),\n  },\n})",
      "autoResize": true,
      "lineHeight": 1.25
    },
