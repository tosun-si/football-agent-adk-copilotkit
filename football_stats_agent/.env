# Loaded by `adk deploy agent_engine --env_file` and bundled with the agent.
# These are runtime env vars for Vertex AI Agent Engine (not Cloud Run).

# Activates AE-native OpenTelemetry instrumentation, which populates the
# "Trace" and "Observability" tabs in the Agent Engine console.
GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY=true

# Captures prompt inputs and response outputs inside spans. Required for
# debug-friendly traces (you see the generated SQL and the BQ result).
# WARNING: would capture PII if user inputs contained any — safe here
# since the dataset is public (Qatar 2022 World Cup stats).
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true
